# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Mercado Pago
MP_ACCESS_TOKEN=your-mercado-pago-access-token

# Admin Authentication Token (gere um token seguro)
# Você pode gerar um com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_PUBLIC_ADMIN_TOKEN=seu-token-seguro-aqui

# URLs de Retorno do Checkout
NEXT_PUBLIC_CHECKOUT_SUCCESS_URL=/checkout/sucesso
NEXT_PUBLIC_CHECKOUT_FAILURE_URL=/checkout/erro
NEXT_PUBLIC_CHECKOUT_PENDING_URL=/checkout/pendente

# Base URL (para produção)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
